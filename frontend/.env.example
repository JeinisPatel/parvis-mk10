# PARVIS Mark 9 frontend env — copy to `.env.local` and edit locally.

# API base — in dev, Next.js proxies /api/* to localhost:8000 (see
# next.config.mjs), so leave NEXT_PUBLIC_API_BASE empty and use relative
# URLs. In production, point to the deployed backend.
# NEXT_PUBLIC_API_BASE=https://parvis-api.fly.dev

# Supabase — Phase A.5. Leave blank until then.
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJh...
