# PARVIS Mark 9 backend env — copy to `.env` and edit locally.
# All vars are prefixed PARVIS_ in code.

# CORS — comma-separated origins. Add Vercel preview URLs in prod.
PARVIS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase — Phase A.5. Leave blank until then.
# PARVIS_SUPABASE_URL=https://xxx.supabase.co
# PARVIS_SUPABASE_ANON_KEY=eyJh...
# PARVIS_SUPABASE_JWT_SECRET=...
